{
	"name": "itson",
	"version": "0.6.3",
	"description": "A CLI tool for configuration-driven management of long-running interactive applications.",
	"keywords": [
		"cli",
		"process",
		"manager",
		"updater"
	],
	"homepage": "https://github.com/kitschpatrol/itson",
	"bugs": "https://github.com/kitschpatrol/itson/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/itson.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"sideEffects": false,
	"type": "module",
	"bin": {
		"itson": "dist/cli.js"
	},
	"files": [
		"dist/*"
	],
	"scripts": {
		"build": "tsdown",
		"clean": "git rm -f pnpm-lock.yaml ; git clean -fdX",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"release": "bumpp --commit 'Release: %s' && pnpm run build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') && pnpm publish",
		"test": "vitest run",
		"test:install": "pnpm link",
		"test:uninstall": "pnpm remove -g itson"
	},
	"dependencies": {
    "@aws-sdk/client-s3": "3.893.0",
    "@clack/prompts": "^1.2.0",
    "@octokit/rest": "^22.0.1",
    "c12": "^3.3.4",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "execa": "^9.6.1",
    "find-versions": "^6.0.0",
    "is-online": "^12.0.2",
    "keytar-forked": "^7.10.0",
    "lognow": "^0.6.1",
    "minimatch": "^10.2.5",
    "plist": "^3.1.0",
    "plur": "^6.0.0",
    "semver": "^7.7.4",
    "yargs": "^18.0.0"
  },
	"devDependencies": {
    "@kitschpatrol/shared-config": "^7.1.0",
    "@types/node": "^22.19.17",
    "@types/plist": "^3.0.5",
    "@types/semver": "^7.7.1",
    "@types/yargs": "^17.0.35",
    "bumpp": "^11.0.1",
    "mdat-plugin-cli-help": "^2.0.2",
    "publint": "^0.3.18",
    "tsdown": "^0.21.7",
    "type-fest": "^5.5.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.2"
  },
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22.18.0"
	}
}
